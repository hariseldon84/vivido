{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@vivido/ui": ["packages/ui/src/index.ts"],
      "@vivido/ui/*": ["packages/ui/src/*"],
      "@vivido/ipc": ["packages/ipc/src/index.ts"],
      "@vivido/ipc/*": ["packages/ipc/src/*"],
      "@vivido/project": ["packages/project/src/index.ts"],
      "@vivido/project/*": ["packages/project/src/*"],
      "@vivido/style-model": ["packages/style-model/src/index.ts"],
      "@vivido/style-model/*": ["packages/style-model/src/*"]
    }
  }
}
